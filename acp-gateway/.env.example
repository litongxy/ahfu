# Environment Variables

# Server
PORT=3000
NODE_ENV=development

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=tongrentang

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=7d

# OpenCode (AI Agent)
OPENCODE_API_KEY=your-opencode-api-key
OPENCODE_API_URL=http://localhost:8080

# ACP Protocol
ACP_VERSION=1.0
ACP_SESSION_EXPIRE_MINUTES=30

# Web Search (optional, falls back to DuckDuckGo HTML when no API key is set)
# Provider: serper | bing | duckduckgo
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_MS=8000
WEB_SEARCH_HL=zh-cn
WEB_SEARCH_GL=cn
WEB_SEARCH_MKT=zh-CN
WEB_SEARCH_DDG_REGION=cn-zh

# API Keys (optional if you use serper/bing)
SERPER_API_KEY=your-serper-api-key
BING_SEARCH_API_KEY=your-bing-search-api-key
